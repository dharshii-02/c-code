#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main() {
    char *s;
    s = malloc(1024 * sizeof(char));
    
    // Read the entire line of input
    scanf("%[^\n]%*c", s);
    
    // Iterate through the string
    for (int i = 0; s[i] != '\0'; i++) {
        if (s[i] == ' ') {
            // Replace space with a newline
            printf("\n");
        } else {
            // Print the character
            printf("%c", s[i]);
        }
    }
    printf("\n");
    
    free(s);
    return 0;
}
